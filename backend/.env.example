# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...
# STRIPE_PRICE_PRECONSULT=price_...
# STRIPE_PRECONSULTATION_AMOUNT_CENTS=5000
# STRIPE_CURRENCY=eur
# STRIPE_MOCK_CHECKOUT=false
# PAYMENT_RESERVATION_TTL_MINUTES=30
# LIVEKIT_URL=wss://your-livekit-host
# LIVEKIT_API_KEY=your-livekit-api-key
# LIVEKIT_API_SECRET=your-livekit-api-secret
# LIVEKIT_TOKEN_TTL_MINUTES=15
# TELECONSULTATION_ACCESS_BEFORE_MINUTES=15
# TELECONSULTATION_ACCESS_AFTER_MINUTES=120

## Maintenance / exports (RGPD)
# EXPORT_CRITICAL_DATA_ALLOWED=false
# MAINTENANCE_ALERT_ENABLED=false
# MAINTENANCE_ALERT_RECIPIENT_EMAIL=admin@example.com
