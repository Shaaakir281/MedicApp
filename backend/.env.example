## Database configuration
# Connection string for SQLAlchemy. The hostname `db` refers to the
# PostgreSQL service defined in docker-compose.yml. For local
# development without Docker, change `db` to `localhost`.
DATABASE_URL=postgresql+psycopg2://postgres:postgres@db:5432/medscript

## JWT settings
# Secret key used to sign JWT tokens. Must be >= 32 characters and rotated
# regularly in production (eg. `openssl rand -hex 32`).
JWT_SECRET_KEY=please_override_with_a_random_32_char_min_value

# Lifetime of access tokens in minutes. Short expirations improve
# security by limiting the validity window of a stolen token.
ACCESS_TOKEN_EXPIRE_MINUTES=15

# Lifetime of refresh tokens in days. Refresh tokens allow users to
# obtain new access tokens without re-entering credentials.
REFRESH_TOKEN_EXPIRE_DAYS=30

## Application metadata
# Base URL used when constructing verification links (should point to the backend)
APP_BASE_URL=http://localhost:8000
# Base URL used when constructing frontend links (verify email, reset password)
FRONTEND_BASE_URL=http://localhost:5173
# Public name of the application (appears in emails)
APP_NAME=MedicApp
# Business timezone used for local appointment slots
APP_TIMEZONE=Europe/Paris
# Comma-separated list of origins allowed to call the API (CORS)
BACKEND_CORS_ORIGINS=http://localhost:5173,http://localhost:3000
REMINDER_LOOKAHEAD_DAYS=7

## SMTP configuration (leave blank for console output in development)
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USERNAME=your-smtp-username
# SMTP_PASSWORD=your-smtp-password
# SMTP_USE_TLS=true
# SMTP_USE_SSL=false
# EMAIL_FROM=no-reply@example.com
# EMAIL_FROM_NAME=MedicApp
# EMAIL_REPLY_TO=support@example.com

## File storage
# STORAGE_BACKEND=local
# STORAGE_LOCAL_PATH=storage
# AZURE_BLOB_CONNECTION_STRING=DefaultEndpointsProtocol=...
# AZURE_BLOB_CONTAINER=medicapp-docs

## Consent & messaging providers
# YOUSIGN_API_KEY=your_yousign_sandbox_api_key
# YOUSIGN_API_BASE_URL=https://api.yousign.app/v3
# YOUSIGN_WEBHOOK_SECRET=replace_me
# SMS_PROVIDER=twilio
# TWILIO_ACCOUNT_SID=your_twilio_sid
# TWILIO_AUTH_TOKEN=your_twilio_token
# TWILIO_FROM_NUMBER=+33700000000

## Feature flags
# FEATURE_ENFORCE_LEGAL_CHECKLIST=false
# FEATURE_PAYMENT_ENABLED=false
# FEATURE_TELECONSULTATION_ENABLED=false
# DEV_TEST_SLOTS_ENABLED=false
